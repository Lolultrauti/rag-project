# Copy to .env and fill in real values. The real .env is gitignored.
# Names here must match app/config.py (case-insensitive).

# --- required ---
GEMINI_API_KEY=your_gemini_api_key_here
DATABASE_URL=postgresql://raguser:ragpassword@localhost:5434/ragdb

# --- Postgres (used by docker-compose; DATABASE_URL above is what the app reads) ---
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# --- operational guards (optional; defaults shown, override to tune) ---
# Per-IP rate limit, slowapi "<count>/<period>" form.
RATE_LIMIT=10/minute
# Hard ceiling on /query calls per UTC day.
DAILY_COST_CAP=300
